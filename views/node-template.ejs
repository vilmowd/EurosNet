                    </div>
                    
                    <button type="submit" <%= maintenanceMode ? 'disabled' : '' %> 
                        style="padding: 15px 40px; font-size: 14pt; font-weight: bold; cursor: pointer; background: #c0c0c0; border: 3px outset #fff; text-transform: uppercase; color: #000;">
                        BRANCH OUT >>
                    </button>
                </div>
            </form>
        </div>
        
        <table width="100%" style="margin-top: 10px;">
            <tr>
                <td><small>Sector: <%= node.id %></small></td>
                <td align="right">
                    <small>
                        <a href="/node/root">Return to Source</a> | 
                        <a href="javascript:history.back()">Go Back</a>
                    </small>
                </td>
            </tr>
        </table>
    </div>
</div>

<img id="ghost-cursor" src="/cursor.gif" style="
    position: fixed; 
    pointer-events: none; /* Important: clicks go 'through' the gif to the buttons */
    z-index: 9999; 
    width: 40px; 
    height: 40px; 
    left: 0; 
    top: 0; 
    display: none;">

<style>
    
    html, body, a, button {
        cursor: none !important;
    }
</style>

<script>
    const ghost = document.getElementById('ghost-cursor');
    
    window.addEventListener('mousemove', (e) => {
        ghost.style.display = 'block';
        
        
        ghost.style.left = e.clientX + 'px';
        ghost.style.top = e.clientY + 'px';
    });

    window.addEventListener('mouseout', () => {
        ghost.style.display = 'none';
    });
</script>

</body>

<script>
    async function updateBTC() {
        try {
            
            const response = await fetch('/api/btc');
            const data = await response.json();
            
            if (data.bitcoin && typeof data.bitcoin.usd !== 'undefined') {
                const val = data.bitcoin.usd;
                const price = val.toLocaleString(undefined, { 
                    minimumFractionDigits: 2, 
                    maximumFractionDigits: 2 
                });
                
                document.getElementById('btc-price').innerText = '$' + price;
            }
        } catch (e) {
            console.log("Ticker Error:", e);
            document.getElementById('btc-price').innerText = 'RETRYING...';
        }
    }
    
    updateBTC();
    setInterval(updateBTC, 120000); 
</script>

<script>
    async function loadNeocities() {
    const feedContainer = document.getElementById('neocities-feed');

    try {
        const res = await fetch('/proxy-browse');
        const sites = await res.json();

        if (!Array.isArray(sites) || sites.length === 0) {
            feedContainer.innerHTML =
                "<center style='font-size:8px;color:#f00;'>NO SIGNAL</center>";
            return;
        }

        let html = `
            <div style="
                display:grid;
                grid-template-columns:repeat(6,1fr);
                gap:4px;
                padding:5px;
                width:100%;
                box-sizing:border-box;">
        `;

        const topSites = sites.slice(0, 18);

        topSites.forEach(site => {
            const siteName = site.name.toLowerCase();
            const siteUrl = `https://${siteName}.neocities.org`;
            const thumbUrl = `https://neocities.org/img/cat.png`;

            html += `
                <div style="text-align:center;min-width:0;">
                    <a href="${siteUrl}" target="_blank"
                       style="text-decoration:none;display:block;">
                       
                        <div style="
                            aspect-ratio:1/1;
                            background:#111;
                            border:1px solid #444;
                            overflow:hidden;">
                            
                            <img class="thumb"
                                 src="${thumbUrl}"
                                 loading="lazy"
                                 style="width:100%;height:100%;object-fit:cover;">
                        </div>

                        <div style="
                            font-size: 13px; /* Increased from 8px */
                            font-weight: bold; /* Added for better visibility */
                            color: #00ff00; /* Changed to green for a terminal look, or keep #fff */
                            font-family: Courier New, monospace;
                            white-space: nowrap;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            background: #000;
                            padding: 3px 0; /* Increased padding */
                            border: 1px solid #444;
                            border-top: none;">
                            ${siteName}
                        </div>
                    </a>
                </div>
            `;
        });

        html += '</div>';
        feedContainer.innerHTML = html;

        const fallbackImage = 'https://neocities.org/img/cat.png';

        document.querySelectorAll('.thumb').forEach(img => {
            img.addEventListener('error', () => {
                if (img.src !== fallbackImage) {
                    img.src = fallbackImage;
                }
            });
        });

    } catch (err) {
        console.error(err);
        feedContainer.innerHTML =
            "<center style='font-size:8px;color:#f00;'>SIGNAL LOST</center>";
    }
}

loadNeocities();

document.addEventListener('DOMContentLoaded', () => {
    const holeLink = document.getElementById('hole-link');
    const glitchBtn = document.getElementById('glitch-btn');

    async function fetchNewHole() {
        holeLink.innerHTML = "SEARCHING THE VOID...";
        
        setTimeout(() => {
            const data = generateRabbitHole(); 
            holeLink.innerText = data.title;
            holeLink.href = data.link;
            
            
            holeLink.style.animation = "none";
            void holeLink.offsetWidth; 
            holeLink.style.animation = "glitch 0.2s 3";
        }, 800);
    }

    if(glitchBtn) glitchBtn.addEventListener('click', fetchNewHole);
});



document.addEventListener('DOMContentLoaded', () => {
    const audioPlayer = document.getElementById('radio-audio');
    const statusText = document.getElementById('radio-status');
    const vizBox = document.getElementById('viz-container');
    const btnPlay = document.getElementById('btn-play');
    const btnStop = document.getElementById('btn-stop');
    const volSlider = document.getElementById('radio-volume');

    const streamUrl = "https://ice1.somafm.com/indiepop-128-mp3";

    
    if (btnPlay && btnStop && audioPlayer) {
        
        btnPlay.addEventListener('click', () => {
            if (!audioPlayer.src || audioPlayer.src === "") {
                audioPlayer.src = streamUrl;
            }
            
            audioPlayer.play().then(() => {
                if (vizBox) vizBox.style.display = 'block';
                statusText.innerHTML = "<marquee scrollamount='3'>NOW PLAYING: 2000s SATELLITE RELAY - BROADCASTING FROM THE PAST...</marquee>";
            }).catch(err => {
                statusText.innerHTML = "ERROR: CLICK PLAY AGAIN";
                console.error("Playback error:", err);
            });
        });

        btnStop.addEventListener('click', () => {
            audioPlayer.pause();
            audioPlayer.src = ""; // Hard stop for stream
            audioPlayer.load();
            if (vizBox) vizBox.style.display = 'none';
            statusText.innerHTML = "SYSTEM PAUSED";
        });

        if (volSlider) {
            volSlider.addEventListener('input', (e) => {
                audioPlayer.volume = e.target.value;
            });
        }
    } else {
        console.error("Radio Error: One or more UI elements not found.");
    }
});

document.addEventListener('DOMContentLoaded', () => {
    const holeText = document.getElementById('hole-text');
    const btnDive = document.getElementById('btn-dive');

    const mysteries = [
        { t: "SECTOR-7 ERROR", l: "https://neocities.org/browse?sort_by=random" },
        { t: "CIPHER: " + Math.random().toString(36).substring(7).toUpperCase(), l: "https://libraryofbabel.info/random.cgi" },
        { t: "ARCHIVE_ENTRY_99", l: "https://www.google.com/search?q=cicada+3301+archive" },
        { t: "GHOST_NODE.exe", l: "https://anvaka.github.io/say-it-with-data/" },
        { t: "VOID_COORDINATES", l: "https://whiteenamel.com/" }
    ];

    
    function generateRabbitHole() {
        if (!holeText) return;
        
        holeText.style.color = "#fff";
        holeText.innerHTML = "DECRYPTING...";

        setTimeout(() => {
            const item = mysteries[Math.floor(Math.random() * mysteries.length)];
            holeText.style.color = "#ff0000";
            holeText.innerHTML = `
                <a href="${item.l}" target="_blank" style="color: #ff0000; text-decoration: none; font-weight: bold;">
                    [!] ${item.t}<br>
                    <span style="font-size:8px; color: #880000;">>> CLICK TO ENTER VOID</span>
                </a>
            `;
        }, 600);
    }

    
    if (btnDive) {
        btnDive.addEventListener('click', generateRabbitHole);
    }
});

async function loadPhantoms() {
    try {
        const res = await fetch('/api/phantoms'); 
        const nodes = await res.json();
        let html = "";
        nodes.forEach(n => {
            html += `<div>> <a href="${n.url}" style="color:#00ff00; text-decoration:none;">${n.title}</a></div>`;
        });
        document.getElementById('phantom-list').innerHTML = html;
    } catch (e) {
        document.getElementById('phantom-list').innerHTML = "NO NODES DETECTED";
    }
}
loadPhantoms();
</script>
