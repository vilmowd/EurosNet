                                    <p><i>The wall is cold and bare.</i></p>
                                    <p><b>BE THE FIRST TO SCRAWL</b></p>
                                </center>
                            <% } %>
                        </div>

                       <form action="/bulletin/post" method="POST" style="background: #808080; padding: 12px; border: 2px inset #fff;">
                            <div style="display: flex; gap: 10px;">
                                <div style="flex: 0 0 120px;">
                                    <input type="text" name="username" placeholder="NAME" style="width: 100%; padding: 8px; border: 2px inset #eee;" required <%= maintenanceMode ? 'disabled' : '' %>>
