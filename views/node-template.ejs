            <p><small>VISITOR COUNT</small></p>
        </center>
        <br>
        <fieldset style="border: 2px ridge #00ff00; background: #000; color: #00ff00; padding: 10px; margin-top: 10px;">
            <legend style="background: #00ff00; color: #000; font-weight: bold; font-size: 10px; padding: 0 5px;">THE ARCHITECT (Live Feed)</legend>
            <div id="phantom-list" style="font-size: 10px; font-family: 'Courier New';">
                Scanning for new nodes...
            </div>
        </fieldset>

        <h3 style="margin-bottom: 5px; font-size: 10pt;">📂 Sub-Branches (Static & Virtual):</h3>
        <div style="background: #ffffff; border: 2px inset #ffffff; padding: 10px; margin-bottom: 25px; min-height: 50px; max-height: 150px; overflow-y: auto;">
            <ul style="margin: 0; padding-left: 20px; list-style-image: url('https://web.archive.org/web/20091027053343/http://geocities.com/SiliconValley/Lab/5980/icons/file.gif');">
                <% if (node.children && node.children.length > 0) { %>
                    <% node.children.forEach(child => { %>
                        <li style="margin-bottom: 8px; display: flex; align-items: center; justify-content: space-between;">
                            <a href="<%= child.isStatic ? '/sites/'+child.id+'.html' : '/node/'+child.id %>" style="font-weight: bold; text-decoration: none; color: #0000ee;">
                                <%= child.title %> <%= child.isStatic ? '[HTML]' : '' %>
