                            <% if (child.isStatic) { %>
                                <a href="/sites/<%= child.id %>.html" download="<%= child.title %>.html" style="text-decoration: none; margin-left: 10px;">
                                    <button type="button" style="font-size: 7pt; cursor: pointer; padding: 1px 4px; background: #c0c0c0; border: 1px outset #fff;">
                                        💾 SAVE SRC
                                    </button>
                                </a>
                            <% } %>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li style="list-style-type: none; margin-left: -20px; color: #808080;">
                        <i>No sub-nodes detected in this sector.</i>
                    </li>
                <% } %>
            </ul>
            
        </div>

        <div class="window" style="margin-top: 30px; border: 3px outset #fff; box-shadow: 2px 2px 10px rgba(0,0,0,0.5);">
            <div class="title-bar" style="background: #000080; padding: 5px 10px;">
                <span style="font-weight: bold; font-size: 11pt;">HELP.HLP - The Architect's Guide</span>
            </div>
            <div class="content-area" style="font-size: 10pt; background: #ffffca; color: #000; padding: 20px;">
                <p><strong>SECTOR CAPACITY:</strong> 2.0 MB (Generous)</p>
                <strong style="font-size: 12pt;">⚠️ THE "INNER HTML" PROTOCOL</strong>
                <p style="margin-bottom: 15px;">
                    The Architect "bakes" your code into a permanent <strong>.html</strong> file. 
                    Do not provide headers or body tags; only provide the <b>fragment</b> you want displayed.
                </p>
                
                <table width="100%" border="1" cellspacing="0" cellpadding="10" style="border-collapse: collapse; font-family: monospace; background: #fff; font-size: 9pt;">
                    <tr bgcolor="#c0c0c0">
                        <td width="50%"><strong>❌ WRONG (Redundant Tags)</strong></td>
                        <td width="50%"><strong>✅ RIGHT (Pure Fragment)</strong></td>
                    </tr>
                    <tr>
                        <td style="color: #800000; vertical-align: top;">
                            &lt;!DOCTYPE html&gt;<br>
                            &lt;html&gt;<br>
                            &lt;head&gt;...&lt;/head&gt;<br>
                            &lt;body&gt;<br>
                            &nbsp;&nbsp;&lt;h1&gt;My Page&lt;/h1&gt;<br>
                            &lt;/body&gt;<br>
                            &lt;/html&gt;
                        </td>
                        <td style="color: #008000; vertical-align: top;">
                            &lt;h1&gt;Welcome to my Sector&lt;/h1&gt;<br>
                            &lt;p&gt;Check out my cool GIF:&lt;/p&gt;<br>
                            &lt;img src="modern-gif-link.gif"&gt;<br>
                            &lt;style&gt;<br>
                            &nbsp;&nbsp;h1 { color: neon-green; }<br>
                            &lt;/style&gt;
                        </td>
                    </tr>
                </table>

                <p style="margin-top: 15px; font-style: italic; border-left: 3px solid #808080; padding-left: 10px;">
                    Note: Your fragment will be injected into a pre-styled &lt;div class="baked-container"&gt;. 
                    You can use &lt;style&gt; tags within your fragment to override local appearances!
                </p>
            </div>
        </div>

        <div style="background: #c0c0c0; padding: 25px; border: 3px outset #ffffff; margin-top: 20px; <%= maintenanceMode ? 'opacity: 0.6;' : '' %>">
            <h2 style="margin-top: 0; color: #000; border-bottom: 2px solid #808080; padding-bottom: 10px;">🚀 DEPLOY NEW SECTOR</h2>
            
            <% if (maintenanceMode) { %>
                <div style="background: red; color: white; padding: 10px; text-align: center; font-weight: bold; margin-bottom: 10px;">
