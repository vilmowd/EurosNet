                    <div style="background: #000; border: 2px inset #fff; padding: 4px; margin-bottom: 5px; height: 35px; display: flex; flex-direction: column; justify-content: space-between;">
                        <div id="radio-status" style="color: #00ff00; font-family: 'Courier New', monospace; font-size: 9px; overflow: hidden; white-space: nowrap;">
                            SYSTEM READY...
                        </div>
                        <div id="viz-container" style="display: none; height: 10px; width: 100%; overflow: hidden;">
                            <img src="https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJ6ZnMxeW5xeXU5Znd6Z3Z6Z3Z6Z3Z6Z3Z6Z3Z6Z3Z6Z3Z6JmVwPXYxX2ludGVybmFsX2dpZl9ieV9pZCZjdD1n/3o7TKMGpxx33vU5BeE/giphy.gif" 
                                style="width: 100%; height: 100%; filter: hue-rotate(90deg) brightness(1.5);">
                        </div>
                    </div>

                    <div style="display: flex; gap: 3px; justify-content: center; align-items: center;">
