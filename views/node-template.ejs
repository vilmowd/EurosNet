                    </div>

                    <audio id="radio-audio" crossorigin="anonymous"></audio>
                </fieldset>
                <br>

                <fieldset style="border: 2px solid #550000; background: #000; color: #ff0000; padding: 10px; font-family: 'Courier New', monospace;">
