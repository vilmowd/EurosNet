<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=1">
    <meta charset="UTF-8">
    <title>SYSTEM ADMINISTRATION</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body style="background-color: #000; margin: 20px;">
    <div class="window" style="max-width: 950px; margin: 0 auto;">
        <div class="title-bar">
            <span>Admin_Terminal.exe - Node Architect v1.5 [Static Bake Edition]</span>
            <span>[X]</span>
        </div>
        
        <div class="content-area">
            <h2 style="margin-top: 0;">System Administration Portal</h2>

            <table width="100%" border="0" cellpadding="5" cellspacing="0">
                <tr valign="top">
                    <td width="50%">
                        <fieldset style="border: 2px solid #808080; background: #c0c0c0; margin-bottom: 20px; padding: 10px;">
                            <legend><strong>Resource_Monitor.exe</strong></legend>
                            <table width="100%" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td width="30%">
                                        <div style="font-size: 9pt;">
                                            <strong>Live Nodes:</strong> <%= stats.liveCount %><br>
                                            <strong>Archived:</strong> <%= stats.deadCount %>
                                        </div>
                                    </td>
                                    <td width="40%" align="center">
                                        <div style="border: 2px inset #fff; background: #eee; height: 18px; width: 90%; position: relative; overflow: hidden;">
                                            <div style="background: #000080; height: 100%; width: <%= stats.ratio %>%;"></div>
                                            <span style="position: absolute; top: 1px; left: 0; width: 100%; text-align: center; font-size: 8pt; color: #000; font-weight: bold; mix-blend-mode: difference;">
                                                Graveyard: <%= stats.ratio %>%
                                            </span>
                                        </div>
                                    </td>
                                    <td width="30%" align="right">
                                        <div style="font-size: 9pt;">
                                            <strong>Net Weight:</strong> <%= stats.totalWeight %> KB<br>
                                            <strong>Status:</strong> <span style="color: #008000;">OPTIMAL</span>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </fieldset>

                        <div style="margin-bottom: 20px;">
                            <form action="/admin/panic" method="POST">
                                <input type="hidden" name="adminPass" value="<%= key %>">
                                <% const panicBtnColor = maintenanceMode ? '#00ff00' : '#ff0000'; %>
                                <button type="submit" 
                                        style="background-color: <%= panicBtnColor %>; color: #fff; font-weight: bold; padding: 12px; width: 100%; border: 4px outset #fff; cursor: pointer; font-family: 'Courier New';">
                                    <%= maintenanceMode ? '🔓 RELEASE SYSTEM LOCKDOWN' : '🚨 ACTIVATE EMERGENCY PANIC MODE' %>
                                </button>
                            </form>
                            <% if (maintenanceMode) { %>
                                <div style="color: #ff0000; font-weight: bold; background: #000; padding: 5px; margin-top: 5px; border: 1px solid red; text-align: center; font-size: 9pt;">
                                    !!! SYSTEM LOCKDOWN ACTIVE - UPLOADS BLOCKED !!!
                                </div>
                            <% } %>
                        </div>

                        <fieldset style="height: 140px;">
                            <legend><strong>Network Broadcast</strong></legend>
                            <form action="/admin/broadcast" method="POST">
                                <input type="hidden" name="adminPass" value="<%= key %>">
                                <p style="font-size: 9pt; margin-bottom: 5px;">Message to display on all nodes:</p>
                                
                                <div style="display: flex; gap: 5px;">
                                    <input type="text" name="message" placeholder="Type message..." style="flex-grow: 1; padding: 3px;">
                                    <button type="submit">TRANSMIT</button>
                                </div>
                            </form>

                            <form action="/admin/broadcast" method="POST" style="margin-top: 10px;">
                                <input type="hidden" name="adminPass" value="<%= key %>">
                                <input type="hidden" name="clearBroadcast" value="true"> 
                                <button type="submit" style="width: 100%; background: #555; color: #fff; font-size: 8pt; cursor: pointer;">
                                    ✖ DISCONNECT BROADCAST SIGNAL
                                </button>
                            </form>
                        </fieldset>


                        <fieldset style="min-height: 105px; margin-bottom: 20px;">
                            <legend><strong>Bulletin Board Management</strong></legend>
                            <div style="max-height: 200px; overflow-y: auto; background: #fff; border: 2px inset #fff; padding: 5px; margin-bottom: 10px; color: #000;">
                                
                                <% if (locals.bulletin && bulletin.length > 0) { %>
                                    <table width="100%" style="font-size: 8pt; border-collapse: collapse;">
                                        <% bulletin.forEach((post, index) => { %>
                                            <tr style="border-bottom: 1px solid #ccc;">
                                                <td style="padding: 3px;">
                                                    <strong><%= post.username %>:</strong> 
                                                    <%= post.message ? post.message.substring(0, 30) : "No content" %>...
                                                </td>
                                                <td align="right" style="padding: 3px;">
                                                    <form action="/admin/delete-bulletin/<%= index %>" method="POST" style="display:inline;">
                                                        <input type="hidden" name="adminPass" value="<%= locals.key %>">
                                                        <button type="submit" style="color: red; font-size: 7pt; cursor: pointer; border: 1px outset #ddd; background: #eee;" onclick="return confirm('Delete this post by <%= post.username %>?')">DEL</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </table>
                                <% } else { %>
                                    <p style="font-size: 8pt; color: #666; text-align: center; padding-top: 10px;">The Graffiti Wall is currently blank.</p>
                                <% } %>
                            </div>

                            <form action="/admin/clear-bulletin" method="POST">
                                <input type="hidden" name="adminPass" value="<%= locals.key %>">
                                <button type="submit" style="color: #a00; font-weight: bold; width: 100%; border: 2px outset #f00; cursor: pointer; padding: 4px;" onclick="return confirm('WARNING: This will permanently erase every post. Proceed?')">☢️ NUCLEAR WIPE BOARD</button>
                            </form>
                        </fieldset>
                    </td>

                    <fieldset style="border: 2px solid #ff0000; background: #1a0000; color: #ff0000; margin-bottom: 20px; padding: 10px; font-family: 'Courier New', monospace;">
                        <legend style="background: #ff0000; color: #000; font-weight: bold; padding: 0 5px;">THE_ARCHITECT.monitor [v2.0]</legend>
                        
                        <div style="font-size: 8pt; margin-bottom: 10px; border-bottom: 1px solid #440000; padding-bottom: 5px;">
                            SCANNING SECTOR FOR AUTONOMOUS GHOST-NODES...
                        </div>

                        <div style="max-height: 150px; overflow-y: auto; background: #000; border: 1px solid #440000; padding: 5px;">
                            <table width="100%" style="font-size: 8pt; border-collapse: collapse;">
                                <% 
                                    // Filter nodes created by the bot
                                    const phantomNodes = allNodes.filter(n => n.author === "THE_ARCHITECT");
                                    if (phantomNodes.length > 0) { 
                                        phantomNodes.forEach(node => { 
                                %>
                                    <tr style="border-bottom: 1px solid #220000;">
                                        <td style="padding: 2px;">[!] NODE_<%= node.id %></td>
                                        <td style="padding: 2px; color: #ff5555;"><%= node.title %></td>
                                        <td align="right" style="padding: 2px;">
                                            <a href="/node/<%= node.id %>" target="_blank" style="color: #00ff00; text-decoration: none;">[VIEW]</a>
                                            <form action="/delete/<%= node.id %>" method="POST" style="display:inline; margin-left: 5px;">
                                                <input type="hidden" name="adminPass" value="<%= key %>">
                                                <input type="hidden" name="reason" value="Exorcised by Admin">
                                                <button type="submit" style="background: transparent; border: none; color: #ff0000; cursor: pointer; font-family: 'Courier New'; font-size: 8pt;">[EXORCISE]</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); } else { %>
                                    <tr><td colspan="3" style="text-align: center; color: #440000; padding: 10px;">NO PHANTOM SIGNALS DETECTED.</td></tr>
                                <% } %>
                            </table>
                        </div>

                        <div style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 7pt;">TOTAL_PHANTOMS: <%= phantomNodes.length %></span>
                            <form action="/admin/trigger-architect" method="POST">
                                <input type="hidden" name="adminPass" value="<%= key %>">
                                <button type="submit" style="background: #440000; color: #ff0000; border: 1px solid #ff0000; font-size: 7pt; cursor: pointer; padding: 2px 5px;">
                                    RE-INITIALIZE ARCHITECT.exe
                                </button>
                            </form>
                        </div>
                    </fieldset>

                    <td width="50%">
                        <fieldset style="height: 105px; margin-bottom: 20px;">
                            <legend><strong>Bulletin Board</strong></legend>
                            <p style="margin: 5px 0; font-size: 9pt;">Current Status: <strong><%= maintenanceMode ? 'LOCKED' : 'ONLINE' %></strong></p>
                            <form action="/admin/clear-bulletin" method="POST">
                                <input type="hidden" name="adminPass" value="<%= key %>">
                                <button type="submit" style="color: #a00; font-weight: bold; width: 100%;" onclick="return confirm('Wipe the entire Graffiti Wall?')">NUCLEAR WIPE BOARD</button>
                            </form>
                        </fieldset>

                        <fieldset style="border: 2px solid #008000; background: #e0ffe0; height: 165px;">
                            <legend><strong>System Janitor (GC v2.0)</strong></legend>
                            <p style="margin: 0; color: #008000; font-size: 8pt;">Scans JSON nodes and Static .html files.</p>
                            <form action="/admin/run-gc" method="POST" style="margin-top: 5px;">
                                <input type="hidden" name="adminPass" value="<%= key %>">
                                <button type="submit" style="background: #008000; color: #fff; font-weight: bold; width: 100%; cursor: pointer; padding: 5px;">
                                    🧹 RUN GARBAGE COLLECTOR
                                </button>
                            </form>
                            <div style="background: #000; color: #0f0; font-family: monospace; font-size: 8pt; margin-top: 8px; height: 60px; overflow-y: auto; padding: 5px; border: 2px inset #808080;">
                                <% if (gcLogs && gcLogs.length > 0) { %>
                                    <% gcLogs.forEach(log => { %> <div>> <%= log %></div> <% }) %>
                                <% } else { %>
                                    <div>> System idle. Waiting for command...</div>
                                <% } %>
                            </div>
                        </fieldset>


                        <div style="margin-top: 10px; padding: 10px; border: 2px dashed #f00;">
                            <strong>Network Integrity:</strong>
                            <a href="/admin/audit-network" style="background: #f00; color: #fff; padding: 5px; text-decoration: none; font-weight: bold;">
                                🔍 RUN CONTENT AUDIT
                            </a>
                        </div>
                    </td>
                </tr>
            </table>

            <br>

            <fieldset style="border: 2px solid #000080; background: #e0e0ff; margin-bottom: 20px;">
                <legend><strong>Backup & Restore Suite</strong></legend>
                <table width="100%">
                    <tr>
                        <td width="50%">
                            <a href="/admin/export?key=<%= key %>" style="text-decoration: none;">
                                <button style="width:100%; background: #000080; color: #fff; padding: 8px;">💾 EXPORT FULL BACKUP (.ZIP)</button>
                            </a>
                        </td>
                        <td width="50%">
                            <form action="/admin/restore" method="POST" enctype="multipart/form-data">
                                <input type="hidden" name="adminPass" value="<%= key %>">
                                <input type="file" name="backupZip" accept=".zip" required style="font-size: 8pt; width: 60%;">
                                <button type="submit" style="background: #a00; color: #fff; padding: 4px 8px;" onclick="return confirm('Overwrite current network?')">☢️ RESTORE</button>
                            </form>
                        </td>
                    </tr>
                </table>
            </fieldset>

            <h3>Active Node Registry</h3>
            <div style="max-height: 400px; overflow-y: auto; border: 2px inset #fff;">
                <table border="1" width="100%" cellpadding="5" style="border-collapse: collapse; background: #eee; color: #000; font-size: 9pt;">
                    <tr style="background: #c0c0c0;">
                        <th>Node ID</th><th>Title / Type</th><th>Parent</th><th>Status</th><th>Actions</th>
                    </tr>
                    <% allNodes.forEach(node => { %>
                    <tr>
                        <td><code><%= node.id %></code></td>
                        <td>
                            <strong><%= node.title %></strong><br>
                            <span style="font-size: 7pt; color: #666;">
                                TYPE: <%= node.isStatic ? '📦 STATIC HTML' : '🖥️ VIRTUAL JSON' %>
                                <% if (node.author === "THE_ARCHITECT") { %>
                                    <br><span style="color: #ff0000; font-weight: bold; font-size: 7pt;">⚠️ PHANTOM SIGNATURE DETECTED</span>
                                <% } %>
                                </span>
                        </td>
                        <td><code><%= node.parentId || '---' %></code></td>
                        <td align="center">
                            <% if(node.isUnderConstruction) { %>
                                <span style="background: #ffff00; padding: 2px; border: 1px solid #000; font-size: 7pt;">HIDDEN</span>
                            <% } else { %>
                                <span style="color: #008000; font-size: 7pt;">● LIVE</span>
                            <% } %>
                        </td>
                        <td>
                            <div style="display: flex; gap: 3px; flex-wrap: wrap;">
                                <a href="<%= node.isStatic ? '/sites/'+node.id+'.html' : '/node/'+node.id %>" target="_blank">
                                    <button style="font-size: 8pt; background: #fff;">VIEW</button>
                                </a>

                                <% if(!node.isStatic) { %>
                                    <a href="/edit/<%= node.id %>?key=<%= key %>">
                                        <button style="font-size: 8pt;">EDIT</button>
                                    </a>
                                <% } %>

                                <form action="/admin/toggle-construction/<%= node.id %>" method="POST">
                                    <input type="hidden" name="adminPass" value="<%= key %>">
                                    <button type="submit" style="font-size: 8pt;"><%= node.isUnderConstruction ? 'PUB' : 'HIDE' %></button>
                                </form>

                                <% if(node.id !== 'root') { %>
                                <form action="/delete/<%= node.id %>" method="POST">
                                    <input type="hidden" name="adminPass" value="<%= key %>">
                                    <input type="hidden" name="reason" id="reason_<%= node.id %>" value="Manual Deletion">
                                    <button type="submit" style="color: #a00; font-size: 8pt; font-weight: bold;" 
                                            onclick="const r = prompt('Reason for deletion?'); if(r) { document.getElementById('reason_<%= node.id %>').value = r; return confirm('Permanently destroy this node?'); } return false;">
                                        DEL
                                    </button>
                                </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </table>
            </div>

            <br>
            <table width="100%">
                <tr>
                    <td><a href="/node/root" style="color: #0000ee;">&lt;&lt; Return to Public Net</a></td>
                    <td align="right">
                        <small>Architect Session: <code><%= key.substring(0,6) %>...</code></small>
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('cemeterySearch');
        if (searchInput) { // This "if" prevents the error
            searchInput.addEventListener('keyup', function() {
                const query = this.value.toLowerCase();
                const rows = document.querySelectorAll('.cemetery-row');
                rows.forEach(row => {
                    const text = row.innerText.toLowerCase();
                    row.style.display = text.includes(query) ? '' : 'none';
                });
            });
        }
    </script>
</body>
</html>